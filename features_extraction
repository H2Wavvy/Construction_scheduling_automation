        def estimate_floors_data_driven(Z):
            Z = np.asarray(Z)

            bin_width = 0.05
            bins = np.arange(Z.min(), Z.max() + bin_width, bin_width)
            counts, edges = np.histogram(Z, bins=bins)
            centers = (edges[:-1] + edges[1:]) / 2

            smooth = gaussian_filter1d(counts, sigma=2)

            peaks, props = find_peaks(
                smooth,
                distance=int(0.5 / bin_width),
                prominence=np.percentile(smooth, 30)
            )

            peak_z = centers[peaks]

            if 0 not in peak_z:
                peak_z = np.append(peak_z, 0)

            dz = np.diff(np.sort(peak_z))
            dz = dz[dz > 0.5]
            
            story_height = np.median(dz)
            
            n_stories = int(round((max(Z) - min(Z)) / story_height))

            prominences = props["prominences"]
            ranked = np.argsort(prominences)[::-1]

            selected_peaks = peaks[ranked[:n_stories]]
            floor_levels = np.sort(centers[selected_peaks])

            # --- force ground floor ---
            tol = 0.2 * story_height
            floor_levels = np.unique(
                np.concatenate(([0.0], floor_levels[np.abs(floor_levels) > tol]))
            )

            return floor_levels, story_height
        
