        def find_all_predecessors(dependancy_graph_val, name_entity):
            predecessors = set()
            queue = [name_entity]
            visited = set()
            
            while queue:
                current = queue.pop(0)
                if current in visited:
                    continue
                visited.add(current)
                
                # Find who supports 'current'
                for supporter, dependents in dependancy_graph_val.items():
                    if current in dependents and supporter not in visited:
                        predecessors.add(supporter)
                        queue.append(supporter)
            
            # Remove __GROUND__ if you don't want it in results
            predecessors.discard("__GROUND__")
            
            return list(predecessors)

        def can_reach_ground(ranges, lowest_point, tolerance=0.5):
            if not ranges:
                # No ranges - check if lowest_point is directly within tolerance of ground
                return lowest_point <= tolerance
            
            # Helper function to check if two z-ranges are within tolerance
            def within_tolerance(z1_min, z1_max, z2_min, z2_max):
                """Check if two ranges can connect (within tolerance)."""
                # Check if the gap between them is <= tolerance
                gap = max(z2_min - z1_max, z1_min - z2_max)
                return gap <= tolerance
            
            # Check if lowest_point connects to a range
            def point_connects_to_range(point, range_dict):
                """Check if a point is within tolerance of a range."""
                return (range_dict["Min_z"] - tolerance <= point <= range_dict["Max_z"] + tolerance)
            
            # Check if a range connects to ground
            def range_connects_to_ground(range_dict):
                """Check if range Min_z is within tolerance of ground (0)."""
                return range_dict["Min_z"] <= tolerance
            
            # Build graph: find which ranges are reachable from lowest_point
            # BFS approach
            queue = deque()
            visited = set()
            
            # Find starting ranges (connected to lowest_point)
            for i, r in enumerate(ranges):
                if point_connects_to_range(lowest_point, r):
                    queue.append(i)
                    visited.add(i)
            
            # If no starting point, we can't proceed
            if not queue:
                return False
            
            # BFS traversal
            while queue:
                current_idx = queue.popleft()
                current_range = ranges[current_idx]
                
                # Check if current range reaches ground
                if range_connects_to_ground(current_range):
                    return True
                
                # Find neighboring ranges
                for i, r in enumerate(ranges):
                    if i not in visited:
                        if within_tolerance(
                            current_range["Min_z"], current_range["Max_z"],
                            r["Min_z"], r["Max_z"]
                        ):
                            queue.append(i)
                            visited.add(i)
            
            # No path found
            return False

        def is_external_object(entity_edges, hull):
              
            def is_point_on_convex_hull_boundary(point, hull, tolerance=None):
                if tolerance is None:
                    bbox = np.ptp(hull.points, axis=0)
                    tolerance = 1e-5 * np.linalg.norm(bbox)

                for equation in hull.equations:
                    normal = equation[:3]
                    d = equation[3]
                    distance = np.dot(normal, point) + d

                    if abs(distance) < tolerance:
                        # Approximate as on plane; optionally further check if it's within the convex polygon face
                        return True
                return False

            entity_vertices = [v for e in entity_edges for v in e]
            entity_vertices = np.array(entity_vertices)

            is_external = 0

            for v in entity_vertices:
                if is_point_on_convex_hull_boundary(v, hull):
                    # Point of the object is on the hull of the structure
                    # Assume this as designation for externality
                    is_external = 1
                    break
                
            return is_external

        def convex_hull_structure(edges_data):
            structures_vertcies = []

            for entity_data in edges_data:
                
                entity_edges = entity_data['Edges']
                structures_vertcies.extend([v for e in entity_edges for v in e])

            vertices = np.array(structures_vertcies)
            hull = ConvexHull(vertices)
            return hull
        
        def total_structural_height(entities_data):
            vertices_z = []

            vertices_2d = []

            for e in entities_data:
