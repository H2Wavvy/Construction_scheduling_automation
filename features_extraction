                vertices_z.extend([v[2]/1000 for e in edges for v in e])

                for edge in edges:
                    for v_1 in edge:
                        vertices_2d.append((v_1[0]/1000, v_1[1]/1000))
            
            vertices_2d = np.array(vertices_2d)

            plan_convex_hull = ConvexHull(vertices_2d)
            plan_area = plan_convex_hull.volume
            
            return max(vertices_z), plan_area
        
