''' Neural Network '''

def neural_network():
    # Intialise parameters
    test_set = 0.0
    training_set = 0.0
    validation_set = 0.0
    best_params = None

    # Optimising cycle
    for activation in ['tanh', 'relu', 'logistic']:
        for i_1 in np.linspace(10, 100, 10):
            for i_2 in np.linspace(10, 100, 10):
                
                # Create model and check for out performance
                pipeline = Pipeline([
                    ('scaler', StandardScaler()),
                    ('mlp', MLPRegressor(
                        solver='adam',        # More robust than lbfgs for complex problems
                        random_state=0,
                        activation=activation,
                        hidden_layer_sizes=[int(i_1), int(i_2)],
                        max_iter=10000,       # adam needs fewer iterations than lbfgs
                        early_stopping=True,  # Stops when validation score stops improving
                        n_iter_no_change=20   # Patience before stopping
                    ))
                ])

                pipeline.fit(X_train, y_train)

                if pipeline.score(X_valid, y_valid) > validation_set:
                    test_set = pipeline.score(X_test, y_test)
                    training_set = pipeline.score(X_train, y_train)
                    validation_set = pipeline.score(X_valid, y_valid)
                    best_params = [activation, int(i_1), int(i_2)]

    print("optimised activation:", best_params[0])
    print("optimised hidden_layer_sizes:", best_params[1], "x", best_params[2])
    print("test_set R^2:", test_set)
    print("training_set R^2:", training_set)
    print("validation_set R^2:", validation_set)

