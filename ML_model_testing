                        random_state=0,
                        activation=i,
                        hidden_layer_sizes=[int(i_1), int(i_2)],  
                        max_iter=100000 # This covers all of the parameters relevant (but not varying hidden_layer_sizes values such as [40, 70] etc)
                    )))
                ])

                NN_classif.fit(X_train_1, y_train_1)

                if NN_classif.score(X_valid_1, y_valid_1) > validation_set:
                    test_set = NN_classif.score(X_test_1, y_test_1)
                    training_set = NN_classif.score(X_train_1, y_train_1)
                    validation_set = NN_classif.score(X_valid_1, y_valid_1)
                    param1 = i_1
                    param2 = i_2
                    layer_size = i

    print("optimised hidden_layer_sizes:", param1, "x", param2)
    print("optimised activation:", layer_size)
    print("test_set accuracy:", test_set)
    print("training_set accuracy:", training_set)
    print("validation_set accuracy:", validation_set)

