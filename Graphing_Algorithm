
    def dependancy_graph(entities, structural_categories, dataframe):

        # -----------------------------
        # BASIC GEOMETRY
        # -----------------------------

        def bbox_from_edges(edges):
            xs, ys, zs = [], [], []
            for e in edges:
                for v in e:
                    xs.append(v[0])
                    ys.append(v[1])
                    zs.append(v[2])
            return {
                "min_x": min(xs), "max_x": max(xs),
                "min_y": min(ys), "max_y": max(ys),
                "min_z": min(zs), "max_z": max(zs),
            }

        # -----------------------------
        # PREPROCESS ENTITIES
        # -----------------------------

        # Function to proccess data into single structure. Irrelevant to those not familiar with prior code. 
        def catagorise_elements(dataframe, entities_data):
            
            # This function is highly relevant to the input data. If the prior sections of code prior to the dependancy_graph
            # function are not well known to the reader, this function should be disregarded. 

            entities_data_wt_cata = []
                
            for entity_data in entities_data:
                
                entity_name = entity_data['Name']
                
                entity_data_cp = entity_data.copy()
                
                for idx, row in dataframe.iterrows():

                    row_name = row['Name']

                    if entity_name in row_name:

                        Material_used_tmp = row['Material/Product']
                        try:
                            Material_used = Material_used_tmp['Design']
                        except:
                            Material_used = Material_used_tmp

                        Material_Product_desc = next(
                            (p for p in total_products_list if p["product_name"] == Material_used),
                            None
                        )
                        Concrete_mix_desc = next(
                            (p for p in concrete_mixes if p["name"] == Material_used),
                            None
                        )
                        Plaster_mix_desc = next(
                            (p for p in plaster_mixes if p["name"] == Material_used),
                            None
                        )
                        Masonry_mix_desc = next(
                            (p for p in masonry_walls if p["name"] == Material_used),
                            None
                        )
                        Buildup_mix_desc = next(
                            (p for p in buildups if p["name"] == Material_used),
                            None
                        )

                        if Material_Product_desc:
                            catagory_used = Material_Product_desc["category"]
                        elif Concrete_mix_desc:
                            catagory_used = 'Concrete built'
                        elif Plaster_mix_desc:
                            catagory_used = 'Plaster'
                        elif Masonry_mix_desc:
                            catagory_used = 'Masonry built'
                        elif Buildup_mix_desc:
                            catagory_used = 'Build-up'

                        break
                
                entity_data_cp["Category"] = catagory_used

                entities_data_wt_cata.append(entity_data_cp)

            return entities_data_wt_cata

        # Dictionary of bounding box data 
        entities_data_wt_cata = catagorise_elements(dataframe, entities)

        processed = {}
        for e in entities_data_wt_cata:
            bbox = bbox_from_edges(e["Edges"])
            processed[e["Name"]] = {
                "category": e["Category"],
                "bbox": bbox,
                "faces": e["Total Faces"]
            }

        dependency_graph = defaultdict(set)

        # Relevant data entity filtering, based on pre-proccessing data
        structural_names = [
            name for name, data in processed.items()
            if data["category"] in structural_categories
        ]

        architectural_names = [
            name for name, data in processed.items()
            if data["category"] not in structural_categories
        ]

        # -----------------------------
        # CORE DETECTION LOGIC
        # -----------------------------

        def detect_dependency(A_name, B_name):
            # Gather the data of both structural entities
            A = processed[A_name]
            B = processed[B_name]
            A_bbox = A["bbox"]
            B_bbox = B["bbox"]
            A_cat = A["category"]
            B_cat = B["category"]

            # Finding the da and db values ;  the maximum span of both entities in the XY plane
            A_xy_span = max(A_bbox["max_x"] - A_bbox["min_x"], A_bbox["max_y"] - A_bbox["min_y"])
            B_xy_span = max(B_bbox["max_x"] - B_bbox["min_x"], B_bbox["max_y"] - B_bbox["min_y"])

            # Computing the span ratio ; how much larger da is compare to db
            span_ratio = max(A_xy_span, B_xy_span) / max(min(A_xy_span, B_xy_span), 1.0)

            # Computing the tolerance based on the quantative investgiation of how the required tolerance varies with 
            # span ratio and the relative size between entities being compared. 
            if span_ratio > 5:
                xy_tol = max(50.0, min(A_xy_span, B_xy_span) * 0.15)
            else:
                xy_tol = max(40.0, min(A_xy_span, B_xy_span) * 0.01)

            # Condition 1: Overlapping in XY plane
            xy_overlap = not (
                A_bbox["max_x"] < B_bbox["min_x"] - xy_tol or
                A_bbox["min_x"] > B_bbox["max_x"] + xy_tol or
                A_bbox["max_y"] < B_bbox["min_y"] - xy_tol or
                A_bbox["min_y"] > B_bbox["max_y"] + xy_tol
            )
            if not xy_overlap:
                return

            z_tol = 20.0

            # Condition 2: Connection in the z axis
            A_on_B = abs(A_bbox["min_z"] - B_bbox["max_z"]) < z_tol
            B_on_A = abs(B_bbox["min_z"] - A_bbox["max_z"]) < z_tol
            if A_on_B:
                dependency_graph[A_name].add(B_name)
                return
            if B_on_A:
                dependency_graph[B_name].add(A_name)
                return

            # Condition 3: Embedment in the z axis
            z_overlap = not (
                A_bbox["max_z"] < B_bbox["min_z"] - z_tol or
                A_bbox["min_z"] > B_bbox["max_z"] + z_tol
            )
            if not z_overlap:
                return

            # Laterally similar ; e.g. spliced beams
            A_mid = (A_bbox["min_z"] + A_bbox["max_z"]) / 2
            B_mid = (B_bbox["min_z"] + B_bbox["max_z"]) / 2
            if A_cat == B_cat and abs(A_mid - B_mid) < 50:
                return

            # Dependency direction: A depends on B only if:
            #   - A's min_z is meaningfully higher than B's min_z (A sits above B), AND
            #   - B's max_z is lower than A's max_z (B doesn't extend above A)
            #     This prevents a beam from depending on the slab above it.
            
            # Condition 4: entity a is above entity b or visa versa
            A_above_B = (A_bbox["min_z"] > B_bbox["min_z"] + 50) and (B_bbox["max_z"] <= A_bbox["max_z"] + z_tol) #Min_z A bigger than Min_z B AND max_z A bigger than max_z B
            B_above_A = (B_bbox["min_z"] > A_bbox["min_z"] + 50) and (A_bbox["max_z"] <= B_bbox["max_z"] + z_tol)

            if A_above_B and not B_above_A:
                dependency_graph[A_name].add(B_name)
            elif B_above_A and not A_above_B:
                dependency_graph[B_name].add(A_name)

        # Compare structural entities with a nested loop ; accordingly add to the dependant graph
        for i in range(len(structural_names)):
            for j in range(i + 1, len(structural_names)): #j = i+1
                A = structural_names[i]
                B = structural_names[j]
                detect_dependency(A, B)

        # Architectural pass ; mock code architecture for when the archctectural elements are also considered
        for A in architectural_names:
            for B in structural_names:
                detect_dependency(A, B)

        # Any entities below zero elevation and not dependant on anything else, assumed as dependant on the ground. 
        for name, data in processed.items():
            if data["bbox"]["min_z"] <= 0 and len(dependency_graph[name]) == 0:
                dependency_graph[name].add("GROUND")

        return dependency_graph
