        def dependancy_identification(entity_data, entity_heiristic_data, constructed_entities_d, dependancy_graph):

            # a) Find the constructed entities this entity is reliant upon
            es_dep_upon = dependancy_graph[entity_data['Name']]

            # b) Find the data of the past constructed entities
            constced_es_data_1 = []
            for entitys, entitys_data in constructed_entities_d.items():
                for dep_e in es_dep_upon:
                    if dep_e in entitys:
                        constced_es_data_1.append(entitys_data)

            seen = []
            constced_es_data = []
            for item in constced_es_data_1:
                if item not in seen:
                    seen.append(item)
                    constced_es_data.append(item)

            # c) Gather requirements for this entity
            pre_tasks_req = entity_heiristic_data['Pre_dependance']
            exec_tasks_req = entity_heiristic_data['Exec_dependance']
            post_tasks_req = entity_heiristic_data['Post_dependance']

            # d) Decipher relationships
            current_entity = entity_data['Name']

            pre_relationships = []
            exec_relationships = []
            post_relationships = []
            for pst_data in constced_es_data:

                pst_data_heuristic = pst_data['Data']
                past_entity_name = pst_data_heuristic['Name']

                # Pre-task 
                if 'FS EXEC' in pre_tasks_req:
                    pre_relationships.append({'Entity':past_entity_name, 'Nature': 'FS EXEC'})
                if 'SS EXEC SOL' in pre_tasks_req:
                    pre_relationships.append({'Entity':current_entity, 'Nature': 'SS EXEC'})

                # Exec-task
                if 'FS EXEC' in exec_tasks_req:
                    exec_relationships.append({'Entity':past_entity_name, 'Nature': 'FS EXEC'})

                # Post-task
                if 'FS EXEC SOL' in post_tasks_req:
                    post_relationships.append({'Entity':current_entity, 'Nature': 'FS EXEC'})

            return pre_relationships, exec_relationships, post_relationships

