        WORK_START_HOUR = 8
        WORK_END_HOUR = 17
        
        def advance_to_next_work_start(from_datetime):
            # Function to go to the next day for the next task, when curing has been completed. 
            # If before 8am same day, snap to 8am
            day_start = from_datetime.replace(hour=WORK_START_HOUR, minute=0, second=0, microsecond=0)
            day_end = from_datetime.replace(hour=WORK_END_HOUR, minute=0, second=0, microsecond=0)
            
            if from_datetime <= day_start:
                return day_start
            elif from_datetime >= day_end:
                # Snap to next day 8am
                next_day = from_datetime + datetime.timedelta(days=1)
                return next_day.replace(hour=WORK_START_HOUR, minute=0, second=0, microsecond=0)
            else:
                # Already within working hours
                return from_datetime

        def advance_working_time(from_datetime, hours):
            remaining_hours = hours

            current = from_datetime

            while remaining_hours > 0:

                # How many hours are left in the current working day
                end_of_day = current.replace(hour=WORK_END_HOUR, minute=0, second=0, microsecond=0)
                hours_left_today = (end_of_day - current).total_seconds() / 3600

                if remaining_hours <= hours_left_today:
                    # Task finishes today
                    current = current + datetime.timedelta(hours=remaining_hours)
                    remaining_hours = 0
                else:
                    # Task spills into next day - jump to next day 8am
                    remaining_hours -= hours_left_today
                    next_day = current + datetime.timedelta(days=1)
                    current = next_day.replace(hour=WORK_START_HOUR, minute=0, second=0, microsecond=0)

            return current

        def advance_working_time_reverse(from_datetime, hours):
            remaining_hours = hours

            current = from_datetime

            while remaining_hours > 0:

                # How many hours of day up until now
                start_of_day = current.replace(hour=WORK_START_HOUR, minute=0, second=0, microsecond=0)
                hours_left_today = (current - start_of_day).total_seconds() / 3600

                if remaining_hours <= hours_left_today:
                    # Task finishes today
                    current = current - datetime.timedelta(hours=remaining_hours)
                    remaining_hours = 0
                else:
                    # Task spills into next day - jump to next day 8am
                    remaining_hours -= hours_left_today
                    previous_day = current - datetime.timedelta(days=1)
                    current = previous_day.replace(hour=WORK_END_HOUR, minute=0, second=0, microsecond=0)

            return current
            
